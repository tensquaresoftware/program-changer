{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug: Standalone",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/${command:cmake.buildDirectory}/Program-Changer_artefacts/${command:cmake.buildType}/Standalone/Program-Changer.app/Contents/MacOS/Program-Changer",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build: Standalone",
            "osx": {
                "type": "lldb",
                "program": "${workspaceFolder}/${command:cmake.buildDirectory}/Program-Changer_artefacts/${command:cmake.buildType}/Standalone/Program-Changer.app/Contents/MacOS/Program-Changer"
            },
            "windows": {
                "type": "cppvsdbg",
                "program": "${workspaceFolder}/${command:cmake.buildDirectory}/Program-Changer_artefacts/${command:cmake.buildType}/Standalone/Program-Changer.exe",
                "MIMode": "windows"
            },
            "linux": {
                "type": "cppdbg",
                "request": "launch",
                "program": "${workspaceFolder}/${command:cmake.buildDirectory}/Program-Changer_artefacts/${command:cmake.buildType}/Standalone/Program-Changer",
                "args": [],
                "cwd": "${workspaceFolder}",
                "MIMode": "gdb",
                "setupCommands": [
                    {
                        "description": "Enable pretty-printing for gdb",
                        "text": "-enable-pretty-printing",
                        "ignoreFailures": true
                    }
                ],
                "preLaunchTask": "Build: Standalone"
            }
        },
        {
            "name": "Debug: AU in Logic Pro",
            "type": "lldb",
            "request": "launch",
            "program": "/Applications/Logic Pro.app/Contents/MacOS/Logic Pro",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build: AU",
            "osx": {
                "type": "lldb"
            }
        },
        {
            "name": "Debug: VST3 in Reaper",
            "type": "lldb",
            "request": "launch",
            "program": "/Applications/REAPER.app/Contents/MacOS/REAPER",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build: VST3",
            "osx": {
                "type": "lldb"
            },
            "windows": {
                "type": "cppvsdbg",
                "program": "C:\\\\Program Files\\\\REAPER (x64)\\\\reaper.exe",
                "MIMode": "windows"
            }
        },
        {
            "name": "Debug: AU in Ableton Live",
            "type": "lldb",
            "request": "launch",
            "program": "/Applications/Ableton Live 12 Suite.app/Contents/MacOS/Live",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build: AU",
            "osx": {
                "type": "lldb"
            }
        }
    ]
}
